{
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.js"],
  "setupFilesAfterFramework": ["<rootDir>/__tests__/setup.js"],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/utils/seed.js",
    "!src/server.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 60,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  },
  "testTimeout": 30000
}
