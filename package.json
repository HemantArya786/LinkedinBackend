{
  "name": "linkedin-backend",
  "version": "1.0.0",
  "description": "Production-ready LinkedIn-like social platform backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seed.js",
    "lint": "eslint src/**/*.js --fix",
    "lint:check": "eslint src/**/*.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload linkedin-api",
    "pm2:stop": "pm2 stop linkedin-api",
    "pm2:logs": "pm2 logs linkedin-api",
    "load-test": "artillery run load-test.yml",
    "docker:build": "docker build -t linkedin-backend .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.2.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "posthog-node": "^5.32.0",
    "socket.io": "^4.6.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "artillery": "^2.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFilesAfterFramework": [
      "./__tests__/setup.js"
    ],
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/utils/seed.js",
      "!src/server.js"
    ]
  },
  "nodemonConfig": {
    "ignore": [
      "__tests__",
      "logs",
      "node_modules"
    ],
    "delay": 500
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
